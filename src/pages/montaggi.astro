---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout
  title="Divisione Montaggi — GB Design Macerata"
  description="Portfolio di montaggi di pregio: cucine complete, cabine armadio, librerie a parete. Lavori residenziali e traslochi nella provincia di Macerata."
>
  <SiteHeader />
  <main class="min-h-screen pt-16">
    <!-- Hero -->
    <section class="bg-warm-50 py-14 sm:py-20 md:py-24">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <a
          href="/divisioni"
          class="text-ink-400 hover:text-brand mb-10 inline-flex items-center gap-2 text-sm transition-colors duration-200"
        >
          ← Torna alle divisioni
        </a>
        <p class="text-brand mb-3 text-xs font-bold tracking-[0.3em] uppercase">Divisione</p>
        <h1
          class="font-display text-ink-900 mb-6 text-3xl leading-tight font-black sm:text-5xl md:text-6xl"
        >
          Montaggi
        </h1>
        <div class="bg-warm-300 mb-8 h-px w-16"></div>
        <p class="text-ink-600 max-w-xl text-lg leading-relaxed">
          Cucine, cabine armadio, librerie, arredi su misura: montiamo tutto con la stessa cura,
          nella provincia di Macerata.
        </p>
      </div>
    </section>

    <!-- Montaggi di pregio -->
    <section class="bg-warm-100 py-12 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 sm:mb-12">
          <p class="text-brand mb-2 text-xs font-bold tracking-[0.3em] uppercase">Portfolio</p>
          <h2 class="font-display text-ink-900 text-2xl leading-snug font-bold sm:text-3xl">
            Montaggi di pregio
          </h2>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
          <div
            class="group border-warm-200 hover:border-warm-300 rounded-2xl border bg-white p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                <path d="M8 21h8M12 17v4"></path>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Cucina a isola
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Civitanova Marche</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Cucina completa con isola centrale, pensili a tutta altezza e colonne frigorifero da
              incasso.
            </p>
          </div>

          <div
            class="group border-warm-200 hover:border-warm-300 rounded-2xl border bg-white p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"
                ></path>
                <path d="M16 3H8l-2 4h12l-2-4z"></path>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Walk-in closet
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Macerata</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Cabina armadio su tre lati con specchi scorrevoli, cassettiere e ripiani illuminati a
              LED.
            </p>
          </div>

          <div
            class="group border-warm-200 hover:border-warm-300 rounded-2xl border bg-white p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <rect x="2" y="3" width="20" height="18" rx="2"></rect>
                <line x1="8" y1="3" x2="8" y2="21"></line>
                <line x1="16" y1="3" x2="16" y2="21"></line>
                <line x1="2" y1="9" x2="22" y2="9"></line>
                <line x1="2" y1="15" x2="22" y2="15"></line>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Libreria floor-to-ceiling
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Porto Recanati</p>
            <p class="text-ink-600 text-base leading-relaxed">
              6 metri lineari dal pavimento al soffitto con scala scorrevole su binario in ottone.
            </p>
          </div>

          <div
            class="group border-warm-200 hover:border-warm-300 rounded-2xl border bg-white p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Cucina lineare
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Recanati</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Top in quarzo, cappa a isola a soffitto e forno da incasso in colonna.
            </p>
          </div>

          <div
            class="group border-warm-200 hover:border-warm-300 rounded-2xl border bg-white p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Soggiorno completo
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Tolentino</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Mobile TV a parete, divano componibile, tavolo allungabile e credenza: tutto in un
              giorno.
            </p>
          </div>

          <div
            class="group border-warm-200 hover:border-warm-300 rounded-2xl border bg-white p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <path
                  d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
                ></path>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Camera completa
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Corridonia</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Armadio scorrevole 4 ante specchio, letto con contenitore, due comodini e cassettiera.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Traslochi -->
    <section class="bg-white py-12 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 sm:mb-12">
          <p class="text-brand mb-2 text-xs font-bold tracking-[0.3em] uppercase">Portfolio</p>
          <h2 class="font-display text-ink-900 text-2xl leading-snug font-bold sm:text-3xl">
            Traslochi
          </h2>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 sm:gap-6">
          <div
            class="group bg-warm-50 border-warm-200 hover:border-warm-300 rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Appartamento 4 locali
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Macerata → Porto Recanati</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Smontaggio completo, trasporto e rimontaggio in un giorno. Cucina, tre armadi, zona
              giorno.
            </p>
          </div>

          <div
            class="group bg-warm-50 border-warm-200 hover:border-warm-300 rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Casa bifamiliare
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Tolentino → Macerata</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Trasloco completo in due giorni: cucina su misura, libreria su parete, cantina e
              garage.
            </p>
          </div>

          <div
            class="group bg-warm-50 border-warm-200 hover:border-warm-300 rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <path
                  d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"
                ></path>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Studio professionale
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Civitanova Marche</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Spostamento di uno studio medico senza interruzione dell'attività: sabato in, lunedì
              operativo.
            </p>
          </div>

          <div
            class="group bg-warm-50 border-warm-200 hover:border-warm-300 rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8"
          >
            <div
              class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-brand transition-colors duration-300 group-hover:text-white"
                aria-hidden="true"
              >
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
              </svg>
            </div>
            <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
              Bar e ristorazione
            </h3>
            <p class="text-brand mb-3 text-xs font-semibold">Recanati</p>
            <p class="text-ink-600 text-base leading-relaxed">
              Smontaggio e rimontaggio di arredi da bar: bancone, scaffalature, arredi sala e cucina
              professionale.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-warm-100 py-14 sm:py-20">
      <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="font-display text-ink-900 mb-4 text-2xl leading-snug font-bold sm:text-3xl">
          Hai un progetto in mente?
        </h2>
        <p class="text-ink-600 mb-8 text-lg leading-relaxed">
          Chiamaci o scrivici: preventivo in giornata.
        </p>
        <a
          href="/#contatti"
          class="bg-brand hover:bg-brand-dark inline-flex items-center justify-center gap-2 rounded-lg px-8 py-4 font-bold text-white shadow-[0_4px_16px_rgba(191,40,43,0.28)] transition-all duration-200 hover:-translate-y-px hover:shadow-[0_6px_22px_rgba(191,40,43,0.38)]"
        >
          Richiedi un preventivo →
        </a>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
