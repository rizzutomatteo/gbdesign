---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const tutti = await getCollection('montaggi');
const montaggiDiPregio = tutti
  .filter((m) => m.data.categoria === 'montaggio-di-pregio')
  .sort((a, b) => b.data.dataLavoro.getTime() - a.data.dataLavoro.getTime());
const traslochi = tutti
  .filter((m) => m.data.categoria === 'trasloco')
  .sort((a, b) => b.data.dataLavoro.getTime() - a.data.dataLavoro.getTime());
---

<Layout
  title="Divisione Montaggi — GB Design Macerata"
  description="Portfolio di montaggi di pregio: cucine complete, cabine armadio, librerie a parete. Lavori residenziali e traslochi nella provincia di Macerata."
>
  <SiteHeader />
  <main class="min-h-screen pt-16">
    <!-- Hero -->
    <section class="bg-warm-50 py-14 sm:py-20 md:py-24">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <a
          href="/divisioni"
          class="text-ink-400 hover:text-brand mb-10 inline-flex items-center gap-2 text-sm transition-colors duration-200"
        >
          ← Torna alle divisioni
        </a>
        <p class="text-brand mb-3 text-xs font-bold tracking-[0.3em] uppercase">Divisione</p>
        <h1
          class="font-display text-ink-900 mb-6 text-3xl leading-tight font-black sm:text-5xl md:text-6xl"
        >
          Montaggi
        </h1>
        <div class="bg-warm-300 mb-8 h-px w-16"></div>
        <p class="text-ink-600 max-w-xl text-lg leading-relaxed">
          Cucine, cabine armadio, librerie, arredi su misura: montiamo tutto con la stessa cura,
          nella provincia di Macerata.
        </p>
      </div>
    </section>

    <!-- Montaggi di pregio -->
    <section class="bg-warm-100 py-12 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 sm:mb-12">
          <p class="text-brand mb-2 text-xs font-bold tracking-[0.3em] uppercase">Portfolio</p>
          <h2 class="font-display text-ink-900 text-2xl leading-snug font-bold sm:text-3xl">
            Montaggi di pregio
          </h2>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
          {
            montaggiDiPregio.map((m) => (
              <div class="group border-warm-200 hover:border-warm-300 rounded-2xl border bg-white p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8">
                {m.data.foto && (
                  <img
                    src={m.data.foto}
                    alt={m.data.titolo}
                    width="400"
                    height="200"
                    class="mb-5 h-44 w-full rounded-xl object-cover"
                    loading="lazy"
                  />
                )}
                <div class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-brand transition-colors duration-300 group-hover:text-white"
                    aria-hidden="true"
                  >
                    <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
                  </svg>
                </div>
                <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
                  {m.data.titolo}
                </h3>
                <p class="text-brand mb-3 text-xs font-semibold">{m.data.luogo}</p>
                <p class="text-ink-600 text-base leading-relaxed">{m.data.descrizione}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Traslochi -->
    <section class="bg-white py-12 sm:py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-10 sm:mb-12">
          <p class="text-brand mb-2 text-xs font-bold tracking-[0.3em] uppercase">Portfolio</p>
          <h2 class="font-display text-ink-900 text-2xl leading-snug font-bold sm:text-3xl">
            Traslochi
          </h2>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 sm:gap-6">
          {
            traslochi.map((m) => (
              <div class="group bg-warm-50 border-warm-200 hover:border-warm-300 rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] sm:p-8">
                {m.data.foto && (
                  <img
                    src={m.data.foto}
                    alt={m.data.titolo}
                    width="400"
                    height="200"
                    class="mb-5 h-44 w-full rounded-xl object-cover"
                    loading="lazy"
                  />
                )}
                <div class="bg-brand/10 group-hover:bg-brand mb-5 flex h-11 w-11 items-center justify-center rounded-xl transition-colors duration-300">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="22"
                    height="22"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-brand transition-colors duration-300 group-hover:text-white"
                    aria-hidden="true"
                  >
                    <rect x="1" y="3" width="15" height="13" />
                    <polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
                    <circle cx="5.5" cy="18.5" r="2.5" />
                    <circle cx="18.5" cy="18.5" r="2.5" />
                  </svg>
                </div>
                <h3 class="font-display text-ink-900 mb-1 text-lg leading-snug font-bold sm:text-xl">
                  {m.data.titolo}
                </h3>
                <p class="text-brand mb-3 text-xs font-semibold">{m.data.luogo}</p>
                <p class="text-ink-600 text-base leading-relaxed">{m.data.descrizione}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-warm-100 py-14 sm:py-20">
      <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="font-display text-ink-900 mb-4 text-2xl leading-snug font-bold sm:text-3xl">
          Hai un progetto in mente?
        </h2>
        <p class="text-ink-600 mb-8 text-lg leading-relaxed">
          Chiamaci o scrivici: preventivo in giornata.
        </p>
        <a
          href="/#contatti"
          class="bg-brand hover:bg-brand-dark inline-flex items-center justify-center gap-2 rounded-lg px-8 py-4 font-bold text-white shadow-[0_4px_16px_rgba(191,40,43,0.28)] transition-all duration-200 hover:-translate-y-px hover:shadow-[0_6px_22px_rgba(191,40,43,0.38)]"
        >
          Richiedi un preventivo →
        </a>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
