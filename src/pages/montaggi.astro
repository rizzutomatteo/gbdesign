---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout
  title="Divisione Montaggi — GB Design Macerata"
  description="Portfolio di montaggi di pregio: cucine complete, cabine armadio, librerie a parete. Lavori residenziali e traslochi nella provincia di Macerata."
>
  <SiteHeader />
  <main class="min-h-screen pt-16">

    <!-- Hero -->
    <section class="py-14 sm:py-20 md:py-24 bg-warm-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <a href="/#servizi" class="inline-flex items-center gap-2 text-ink-400 text-sm hover:text-brand transition-colors duration-200 mb-10">
          ← Torna alle divisioni
        </a>
        <p class="text-brand text-xs font-bold uppercase tracking-[0.3em] mb-3">Divisione</p>
        <h1 class="font-display font-black text-ink-900 text-3xl sm:text-5xl md:text-6xl leading-tight mb-6">Montaggi</h1>
        <div class="w-16 h-px bg-warm-300 mb-8"></div>
        <p class="text-ink-600 text-lg leading-relaxed max-w-xl">
          Cucine, cabine armadio, librerie, arredi su misura: montiamo tutto con la stessa cura,
          nella provincia di Macerata.
        </p>
      </div>
    </section>

    <!-- Montaggi di pregio -->
    <section class="py-12 sm:py-16 bg-warm-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="mb-10 sm:mb-12">
          <p class="text-brand text-xs font-bold uppercase tracking-[0.3em] mb-2">Portfolio</p>
          <h2 class="font-display font-bold text-ink-900 text-2xl sm:text-3xl leading-snug">Montaggi di pregio</h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">

          <div class="group bg-white rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                <path d="M8 21h8M12 17v4"></path>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Cucina a isola</h3>
            <p class="text-brand text-xs font-semibold mb-3">Civitanova Marche</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Cucina completa con isola centrale, pensili a tutta altezza e colonne frigorifero da incasso.
            </p>
          </div>

          <div class="group bg-white rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"></path>
                <path d="M16 3H8l-2 4h12l-2-4z"></path>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Walk-in closet</h3>
            <p class="text-brand text-xs font-semibold mb-3">Macerata</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Cabina armadio su tre lati con specchi scorrevoli, cassettiere e ripiani illuminati a LED.
            </p>
          </div>

          <div class="group bg-white rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <rect x="2" y="3" width="20" height="18" rx="2"></rect>
                <line x1="8" y1="3" x2="8" y2="21"></line>
                <line x1="16" y1="3" x2="16" y2="21"></line>
                <line x1="2" y1="9" x2="22" y2="9"></line>
                <line x1="2" y1="15" x2="22" y2="15"></line>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Libreria floor-to-ceiling</h3>
            <p class="text-brand text-xs font-semibold mb-3">Porto Recanati</p>
            <p class="text-ink-600 leading-relaxed text-base">
              6 metri lineari dal pavimento al soffitto con scala scorrevole su binario in ottone.
            </p>
          </div>

          <div class="group bg-white rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Cucina lineare</h3>
            <p class="text-brand text-xs font-semibold mb-3">Recanati</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Top in quarzo, cappa a isola a soffitto e forno da incasso in colonna.
            </p>
          </div>

          <div class="group bg-white rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Soggiorno completo</h3>
            <p class="text-brand text-xs font-semibold mb-3">Tolentino</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Mobile TV a parete, divano componibile, tavolo allungabile e credenza: tutto in un giorno.
            </p>
          </div>

          <div class="group bg-white rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Camera completa</h3>
            <p class="text-brand text-xs font-semibold mb-3">Corridonia</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Armadio scorrevole 4 ante specchio, letto con contenitore, due comodini e cassettiera.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Traslochi -->
    <section class="py-12 sm:py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <div class="mb-10 sm:mb-12">
          <p class="text-brand text-xs font-bold uppercase tracking-[0.3em] mb-2">Portfolio</p>
          <h2 class="font-display font-bold text-ink-900 text-2xl sm:text-3xl leading-snug">Traslochi</h2>
        </div>

        <div class="grid sm:grid-cols-2 gap-5 sm:gap-6">

          <div class="group bg-warm-50 rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Appartamento 4 locali</h3>
            <p class="text-brand text-xs font-semibold mb-3">Macerata → Porto Recanati</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Smontaggio completo, trasporto e rimontaggio in un giorno. Cucina, tre armadi, zona giorno.
            </p>
          </div>

          <div class="group bg-warm-50 rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Casa bifamiliare</h3>
            <p class="text-brand text-xs font-semibold mb-3">Tolentino → Macerata</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Trasloco completo in due giorni: cucina su misura, libreria su parete, cantina e garage.
            </p>
          </div>

          <div class="group bg-warm-50 rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Studio professionale</h3>
            <p class="text-brand text-xs font-semibold mb-3">Civitanova Marche</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Spostamento di uno studio medico senza interruzione dell'attività: sabato in, lunedì operativo.
            </p>
          </div>

          <div class="group bg-warm-50 rounded-2xl p-7 sm:p-8 shadow-[0_2px_12px_rgba(26,22,18,0.07)] hover:shadow-[0_10px_36px_rgba(26,22,18,0.12)] border border-warm-200 hover:border-warm-300 transition-all duration-300 hover:-translate-y-0.5">
            <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mb-5 transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
                <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
              </svg>
            </div>
            <h3 class="font-display font-bold text-ink-900 text-lg sm:text-xl mb-1 leading-snug">Bar e ristorazione</h3>
            <p class="text-brand text-xs font-semibold mb-3">Recanati</p>
            <p class="text-ink-600 leading-relaxed text-base">
              Smontaggio e rimontaggio di arredi da bar: bancone, scaffalature, arredi sala e cucina professionale.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-14 sm:py-20 bg-warm-100">
      <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-display font-bold text-ink-900 text-2xl sm:text-3xl mb-4 leading-snug">Hai un progetto in mente?</h2>
        <p class="text-ink-600 text-lg mb-8 leading-relaxed">Chiamaci o scrivici: preventivo in giornata.</p>
        <a
          href="/#contatti"
          class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-dark text-white px-8 py-4 rounded-lg font-bold transition-all duration-200 shadow-[0_4px_16px_rgba(191,40,43,0.28)] hover:shadow-[0_6px_22px_rgba(191,40,43,0.38)] hover:-translate-y-px"
        >
          Richiedi un preventivo →
        </a>
      </div>
    </section>

  </main>
  <SiteFooter />
</Layout>
