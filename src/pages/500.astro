---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { site } from '../config/site';
---

<Layout
  title="Errore del server — GB Design Macerata"
  description="Si è verificato un errore. Riprova tra qualche istante."
>
  <SiteHeader />
  <main class="min-h-screen pt-16">
    <section class="bg-warm-50 relative overflow-hidden py-14 sm:py-24 md:py-32">
      <div
        class="from-warm-100 pointer-events-none absolute inset-y-0 right-0 w-1/2 bg-gradient-to-l to-transparent"
      >
      </div>
      <div
        class="font-display text-warm-200/70 pointer-events-none absolute top-1/2 right-8 hidden -translate-y-1/2 text-[10rem] leading-none font-black select-none sm:text-[16rem] md:block"
      >
        500
      </div>

      <div class="relative z-10 mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
        <p class="text-brand mb-3 text-xs font-bold tracking-[0.3em] uppercase">Errore 500</p>
        <h1 class="font-display text-ink-900 mb-5 text-3xl leading-tight font-black sm:text-5xl">
          Qualcosa è andato storto
        </h1>
        <div class="bg-warm-300 mb-8 h-px w-16"></div>
        <p class="text-ink-600 mb-4 text-lg leading-relaxed">
          Si è verificato un errore inaspettato. Non dipende da te.
        </p>
        <p class="text-ink-400 mb-10 text-base leading-relaxed">
          Riprova tra qualche istante. Se il problema persiste, contattaci direttamente: siamo
          sempre disponibili per telefono o WhatsApp.
        </p>
        <div class="flex flex-col gap-4 sm:flex-row">
          <a
            href="/"
            class="bg-brand hover:bg-brand-dark inline-flex items-center justify-center gap-2 rounded-lg px-8 py-4 font-bold text-white shadow-[0_4px_16px_rgba(191,40,43,0.28)] transition-all duration-200 hover:-translate-y-px hover:shadow-[0_6px_22px_rgba(191,40,43,0.38)]"
          >
            ← Torna alla home
          </a>
          <a
            href={`tel:${site.phone}`}
            class="hover:bg-warm-100 text-ink-700 border-warm-200 hover:border-warm-300 inline-flex items-center justify-center gap-2 rounded-lg border bg-white px-8 py-4 font-semibold transition-all duration-200"
          >
            Chiamaci
          </a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
