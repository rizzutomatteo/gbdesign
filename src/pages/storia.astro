---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout
  title="La nostra storia — GB Design Montaggio Cucine e Mobili Macerata"
  description="Dal 2008 ad oggi: la storia di GB Design, specialisti nel montaggio cucine e mobili a Macerata."
>
  <SiteHeader />
  <main class="min-h-screen pt-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <p class="text-brand text-xs font-bold uppercase tracking-[0.2em] mb-3">La nostra storia</p>
      <h1 class="text-gray-900 text-4xl sm:text-5xl font-black mb-6">Dal 2008 ad oggi</h1>
      <div class="w-16 h-1 bg-brand mb-8 rounded-full"></div>
      <p class="text-gray-500 text-lg leading-relaxed">
        Contenuto in arrivo. Questa pagina sarà presto aggiornata con la storia di GB Design.
      </p>
      <a href="/" class="mt-10 inline-flex items-center gap-2 text-brand font-semibold hover:underline">
        ← Torna alla home
      </a>
    </div>
  </main>
  <SiteFooter />
</Layout>
