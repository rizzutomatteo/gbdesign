---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const tappe = await getCollection('tappe-storia');
const tappeOrdinate = tappe.sort((a, b) => a.data.anno - b.data.anno);
---

<Layout
  title="La nostra storia — GB Design Montaggio Cucine e Mobili Macerata"
  description="Dal 2008 ad oggi: la storia di GB Design, specialisti nel montaggio cucine e mobili a Macerata."
>
  <SiteHeader />
  <main class="min-h-screen pt-16">
    <div class="mx-auto max-w-3xl px-4 py-20 sm:px-6 lg:px-8">
      <p class="text-brand mb-3 text-xs font-bold tracking-[0.2em] uppercase">La nostra storia</p>
      <h1 class="font-display text-ink-900 mb-6 text-4xl font-black sm:text-5xl">
        Dal 2008 ad oggi
      </h1>
      <div class="bg-brand mb-12 h-1 w-16 rounded-full"></div>

      <ol class="border-warm-200 relative border-l" aria-label="Timeline della storia di GB Design">
        {
          tappeOrdinate.map((tappa) => (
            <li class="mb-10 ml-8 last:mb-0">
              <span class="bg-brand ring-warm-50 absolute -left-3 flex h-6 w-6 items-center justify-center rounded-full ring-4">
                <span class="sr-only">Anno {tappa.data.anno}</span>
              </span>
              <p class="text-brand mb-1 text-xs font-bold tracking-[0.2em] uppercase">
                {tappa.data.anno}
              </p>
              <h2 class="font-display text-ink-900 mb-2 text-xl font-bold">{tappa.data.titolo}</h2>
              <p class="text-ink-600 text-base leading-relaxed">{tappa.data.descrizione}</p>
            </li>
          ))
        }
      </ol>

      <a
        href="/"
        class="text-brand mt-12 inline-flex items-center gap-2 font-semibold hover:underline"
      >
        ← Torna alla home
      </a>
    </div>
  </main>
  <SiteFooter />
</Layout>
