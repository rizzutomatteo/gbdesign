---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Layout
  title="Servizi — GB Design Montaggio Cucine e Mobili Macerata"
  description="Montaggio cucine, armadi, librerie e qualsiasi mobile in provincia di Macerata. Scopri tutti i servizi di GB Design."
>
  <SiteHeader />
  <main class="min-h-screen pt-16">
    <div class="mx-auto max-w-3xl px-4 py-20 sm:px-6 lg:px-8">
      <p class="text-brand mb-3 text-xs font-bold tracking-[0.2em] uppercase">Cosa facciamo</p>
      <h1 class="text-ink-900 mb-6 text-4xl font-black sm:text-5xl">I nostri servizi</h1>
      <div class="bg-brand mb-8 h-1 w-16 rounded-full"></div>
      <p class="text-ink-600 text-lg leading-relaxed">
        Contenuto in arrivo. Questa pagina sarà presto aggiornata con il dettaglio di tutti i
        servizi.
      </p>
      <a
        href="/"
        class="text-brand mt-10 inline-flex items-center gap-2 font-semibold hover:underline"
      >
        ← Torna alla home
      </a>
    </div>
  </main>
  <SiteFooter />
</Layout>
