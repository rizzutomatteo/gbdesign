---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const tuttiPassaggi = await getCollection('passaggi');
const passaggi = tuttiPassaggi.sort((a, b) => a.data.ordine - b.data.ordine);
---

<Layout
  title="Divisione Progettazione — GB Design Macerata"
  description="Come lavoriamo: dalla prima consulenza alla consegna chiavi in mano. Scopri il processo di GB Design, passo dopo passo."
>
  <SiteHeader />
  <main class="min-h-screen pt-16">
    <!-- Hero -->
    <section class="bg-warm-50 py-14 sm:py-20 md:py-24">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <a
          href="/divisioni"
          class="text-ink-400 hover:text-brand mb-10 inline-flex items-center gap-2 text-sm transition-colors duration-200"
        >
          ← Torna alle divisioni
        </a>
        <p class="text-brand mb-3 text-xs font-bold tracking-[0.3em] uppercase">Divisione</p>
        <h1
          class="font-display text-ink-900 mb-6 text-3xl leading-tight font-black sm:text-5xl md:text-6xl"
        >
          Progettazione
        </h1>
        <div class="bg-warm-300 mb-8 h-px w-16"></div>
        <p class="text-ink-600 max-w-xl text-lg leading-relaxed">
          Prima ascoltiamo, poi pianifichiamo, poi eseguiamo. Ecco come funziona ogni nostro lavoro,
          dalla prima telefonata alla consegna.
        </p>
      </div>
    </section>

    <!-- Processo -->
    <section class="bg-warm-100 py-12 sm:py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="mb-12 text-center sm:mb-14">
          <p class="text-brand mb-3 text-xs font-bold tracking-[0.3em] uppercase">
            Il nostro metodo
          </p>
          <h2
            class="font-display text-ink-900 text-2xl leading-snug font-bold sm:text-3xl md:text-4xl"
          >
            Come lavoriamo
          </h2>
        </div>

        <div class="space-y-5">
          {
            passaggi.map((p, i) => {
              const isLast = i === passaggi.length - 1;
              return (
                <div
                  class={
                    isLast
                      ? 'group bg-ink-900 flex items-start gap-6 rounded-2xl p-7 sm:p-8'
                      : 'group border-warm-200 hover:border-warm-300 flex items-start gap-6 rounded-2xl border bg-white p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] transition-all duration-300 hover:shadow-[0_8px_32px_rgba(26,22,18,0.11)] sm:p-8'
                  }
                >
                  <div class="bg-brand flex h-11 w-11 flex-none items-center justify-center rounded-xl shadow-[0_2px_10px_rgba(191,40,43,0.2)]">
                    <span class="font-display text-base leading-none font-black text-white">
                      {String(p.data.ordine).padStart(2, '0')}
                    </span>
                  </div>
                  <div>
                    <h3
                      class={`font-display mb-2 text-lg leading-snug font-bold sm:text-xl ${isLast ? 'text-white' : 'text-ink-900'}`}
                    >
                      {p.data.titolo}
                    </h3>
                    <p
                      class={`text-base leading-relaxed ${isLast ? 'text-warm-300' : 'text-ink-600'}`}
                    >
                      {p.data.descrizione}
                    </p>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-white py-14 sm:py-20">
      <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
        <h2 class="font-display text-ink-900 mb-4 text-2xl leading-snug font-bold sm:text-3xl">
          Pronto a iniziare?
        </h2>
        <p class="text-ink-600 mb-8 text-lg leading-relaxed">
          Il primo passo è una telefonata. Il resto lo facciamo noi.
        </p>
        <a
          href="/#contatti"
          class="bg-brand hover:bg-brand-dark inline-flex items-center justify-center gap-2 rounded-lg px-8 py-4 font-bold text-white shadow-[0_4px_16px_rgba(191,40,43,0.28)] transition-all duration-200 hover:-translate-y-px hover:shadow-[0_6px_22px_rgba(191,40,43,0.38)]"
        >
          Richiedi un preventivo →
        </a>
      </div>
    </section>
  </main>
  <SiteFooter />
</Layout>
