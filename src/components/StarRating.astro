---
interface Props {
  rating: number;
  max?: number;
  size?: number;
}
const { rating, max = 5, size = 14 } = Astro.props;
---

<div class="flex gap-0.5" role="img" aria-label={`${rating} su ${max} stelle`}>
  {
    Array.from({ length: rating }).map(() => (
      <svg
        width={size}
        height={size}
        viewBox="0 0 24 24"
        fill="#bf282b"
        stroke="none"
        aria-hidden="true"
      >
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
      </svg>
    ))
  }
</div>
