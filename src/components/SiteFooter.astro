---
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
import { site, nav } from '../config/site';
---

<footer class="bg-ink-900 text-white">
  <!-- Sottile accento brand in cima -->
  <div class="bg-brand/40 h-px"></div>

  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-16 lg:px-8">
    <div class="mb-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-2">
        <a href="/" class="group mb-5 flex items-center gap-3">
          <Image
            src={logo}
            alt="GB Design"
            width={38}
            height={38}
            class="flex-shrink-0 rounded object-contain"
          />
          <span
            class="font-display group-hover:text-brand/90 text-lg font-bold tracking-tight text-white transition-colors duration-200"
            >{site.name}</span
          >
        </a>
        <p class="text-ink-200/70 max-w-xs text-sm leading-relaxed">
          {site.description}
        </p>
      </div>

      <!-- Esplora -->
      <div>
        <h3 class="mb-5 text-[10px] font-bold tracking-[0.3em] text-white/50 uppercase">Esplora</h3>
        <ul class="space-y-3">
          {
            nav
              .filter((item) => item.inFooter !== false)
              .map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-ink-200/70 text-sm transition-colors duration-200 hover:text-white"
                  >
                    {item.footerLabel ?? item.label}
                  </a>
                </li>
              ))
          }
        </ul>
      </div>

      <!-- Contatti -->
      <div>
        <h3 class="mb-5 text-[10px] font-bold tracking-[0.3em] text-white/50 uppercase">
          Contatti
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href={`tel:${site.phone}`}
              class="text-ink-200/70 text-sm transition-colors duration-200 hover:text-white"
            >
              {site.phoneDisplay}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${site.email}`}
              class="text-ink-200/70 text-sm transition-colors duration-200 hover:text-white"
            >
              {site.email}
            </a>
          </li>
          {
            site.social.facebook && (
              <li>
                <a
                  href={site.social.facebook}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ink-200/70 text-sm transition-colors duration-200 hover:text-white"
                >
                  Facebook
                </a>
              </li>
            )
          }
          {
            site.social.instagram && (
              <li>
                <a
                  href={site.social.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-ink-200/70 text-sm transition-colors duration-200 hover:text-white"
                >
                  Instagram
                </a>
              </li>
            )
          }
        </ul>
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 sm:flex-row"
    >
      <p class="text-ink-200/40 text-xs font-light">
        © {new Date().getFullYear()}
        {site.name} — P.IVA {site.piva} — REA {site.rea}
      </p>
      <div class="flex gap-5">
        <a
          href="/privacy"
          class="text-ink-200/40 hover:text-ink-200/80 text-xs font-light transition-colors duration-200"
          >Privacy Policy</a
        >
        <a
          href="/cookie"
          class="text-ink-200/40 hover:text-ink-200/80 text-xs font-light transition-colors duration-200"
          >Cookie Policy</a
        >
        <a
          href="/termini"
          class="text-ink-200/40 hover:text-ink-200/80 text-xs font-light transition-colors duration-200"
          >Termini e Condizioni</a
        >
      </div>
    </div>
  </div>
</footer>
