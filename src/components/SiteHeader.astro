---
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
import { site } from '../config/site';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-black/95 backdrop-blur-sm">
  <div class="absolute bottom-0 left-0 right-0 h-px bg-white/10"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 group">
        <Image
          src={logo}
          alt="GB Design logo"
          width={36}
          height={36}
          class="rounded-sm object-contain"
        />
        <span
          class="text-white font-bold text-base hidden sm:block group-hover:text-brand transition-colors duration-200"
        >
          {site.name}
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-7" aria-label="Navigazione principale">
        <a href="/missione" class="text-gray-400 hover:text-white text-sm font-medium transition-colors duration-200">Mission</a>
        <a href="/storia" class="text-gray-400 hover:text-white text-sm font-medium transition-colors duration-200">Storia</a>
        <a href="/servizi" class="text-gray-400 hover:text-white text-sm font-medium transition-colors duration-200">Servizi</a>
        <a href="#recensioni" class="text-gray-400 hover:text-white text-sm font-medium transition-colors duration-200">Recensioni</a>
        <a href="#lavori" class="text-gray-400 hover:text-white text-sm font-medium transition-colors duration-200">Lavori</a>
        <a href="#contatti" class="text-gray-400 hover:text-white text-sm font-medium transition-colors duration-200">Contatti</a>
      </nav>

      <div class="flex items-center gap-2 sm:gap-3">
        <a
          href={`tel:${site.phone}`}
          aria-label={`Chiama ${site.phoneDisplay}`}
          class="bg-brand hover:bg-brand-dark text-white px-3 py-2 rounded text-sm font-semibold transition-colors duration-200 flex items-center gap-1.5 flex-shrink-0"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.19 6.19l1.73-1.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
          <span class="hidden sm:inline">{site.phoneDisplay}</span>
        </a>
        <button
          id="menu-toggle"
          aria-label="Apri menu"
          aria-expanded="false"
          class="lg:hidden text-white p-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden bg-black border-t border-white/10">
    <nav class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1" aria-label="Menu mobile">
      <a href="/missione" class="text-gray-300 hover:text-white py-2 text-sm font-medium transition-colors">Mission</a>
      <a href="/storia" class="text-gray-300 hover:text-white py-2 text-sm font-medium transition-colors">Storia</a>
      <a href="/servizi" class="text-gray-300 hover:text-white py-2 text-sm font-medium transition-colors">Servizi</a>
      <a href="#recensioni" class="text-gray-300 hover:text-white py-2 text-sm font-medium transition-colors">Recensioni</a>
      <a href="#lavori" class="text-gray-300 hover:text-white py-2 text-sm font-medium transition-colors">Lavori</a>
      <a href="#contatti" class="text-gray-300 hover:text-white py-2 text-sm font-medium transition-colors">Contatti</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isHidden));
  });
</script>
