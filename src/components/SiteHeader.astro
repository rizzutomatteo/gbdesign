---
import { Image } from 'astro:assets';
import logo from '../assets/logo.svg';
import { site, nav } from '../config/site';
---

<header
  class="border-warm-200 fixed top-0 right-0 left-0 z-50 border-b bg-white/96 backdrop-blur-sm transition-shadow duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="group flex items-center gap-3">
        <Image
          src={logo}
          alt="GB Design logo"
          width={34}
          height={34}
          class="flex-shrink-0 rounded object-contain"
        />
        <span
          class="font-display text-ink-900 group-hover:text-brand hidden text-[1.05rem] leading-none font-bold tracking-tight transition-colors duration-200 sm:block"
        >
          {site.name}
        </span>
      </a>

      <nav class="hidden items-center gap-7 lg:flex" aria-label="Navigazione principale">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="text-ink-600 hover:text-ink-900 text-sm font-medium transition-colors duration-200"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-2 sm:gap-3">
        <a
          href={`tel:${site.phone}`}
          aria-label={`Chiama ${site.phoneDisplay}`}
          class="bg-brand hover:bg-brand-dark flex flex-shrink-0 items-center gap-1.5 rounded px-3 py-2 text-sm font-semibold text-white shadow-sm transition-colors duration-200"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.19 6.19l1.73-1.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
            ></path>
          </svg>
          <span class="hidden sm:inline">{site.phoneDisplay}</span>
        </a>
        <button
          id="menu-toggle"
          aria-label="Apri menu"
          aria-expanded="false"
          class="text-ink-700 p-1 lg:hidden"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="border-warm-200 hidden border-t bg-white lg:hidden">
    <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-4 py-4" aria-label="Menu mobile">
      {
        nav.map((item, i) => (
          <a
            href={item.href}
            class={`text-ink-600 hover:text-ink-900 py-2.5 text-sm font-medium transition-colors${i < nav.length - 1 ? ' border-warm-100 border-b' : ''}`}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    if (!menu || !toggle) return;
    const isOpen = !menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Chiudi menu' : 'Apri menu');
  });
</script>
