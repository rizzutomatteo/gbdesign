---
import { site } from '../../config/site';
---

<section id="contatti" class="py-14 sm:py-20 md:py-24 bg-warm-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12 sm:mb-16">
      <p class="text-brand text-[10px] sm:text-xs font-bold uppercase tracking-[0.3em] mb-3">Siamo qui</p>
      <h2 class="font-display font-bold text-ink-900 text-2xl sm:text-3xl md:text-4xl mb-4 leading-snug">Contatti e informazioni</h2>
      <p class="text-ink-600 max-w-lg mx-auto leading-relaxed text-sm sm:text-base font-light">
        Il modo più veloce per un preventivo gratuito è una telefonata.
        Ma puoi anche scriverci su WhatsApp o mandarci un'email.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-5 mb-12 sm:mb-14">

      <a href={`tel:${site.phone}`}
        class="group bg-white rounded-2xl p-6 border border-warm-200 shadow-[0_2px_10px_rgba(26,22,18,0.06)] hover:shadow-[0_8px_28px_rgba(26,22,18,0.11)] hover:-translate-y-0.5 transition-all duration-300 text-center">
        <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mx-auto mb-4 transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.19 6.19l1.73-1.73a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-wider text-ink-400 mb-2">Telefono</p>
        <p class="text-ink-900 font-bold text-sm">{site.phoneDisplay}</p>
      </a>

      <a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener noreferrer"
        class="group bg-white rounded-2xl p-6 border border-warm-200 shadow-[0_2px_10px_rgba(26,22,18,0.06)] hover:shadow-[0_8px_28px_rgba(26,22,18,0.11)] hover:-translate-y-0.5 transition-all duration-300 text-center">
        <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mx-auto mb-4 transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"></path>
          </svg>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-wider text-ink-400 mb-2">WhatsApp</p>
        <p class="text-ink-900 font-bold text-sm">Scrivici ora</p>
      </a>

      <a href={`mailto:${site.email}`}
        class="group bg-white rounded-2xl p-6 border border-warm-200 shadow-[0_2px_10px_rgba(26,22,18,0.06)] hover:shadow-[0_8px_28px_rgba(26,22,18,0.11)] hover:-translate-y-0.5 transition-all duration-300 text-center">
        <div class="w-11 h-11 bg-brand/10 group-hover:bg-brand rounded-xl flex items-center justify-center mx-auto mb-4 transition-colors duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand group-hover:text-white transition-colors duration-300" aria-hidden="true">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <polyline points="22,6 12,13 2,6"></polyline>
          </svg>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-wider text-ink-400 mb-2">Email</p>
        <p class="text-ink-900 font-bold text-sm truncate">{site.email}</p>
      </a>

      <div class="bg-white rounded-2xl p-6 border border-warm-200 shadow-[0_2px_10px_rgba(26,22,18,0.06)] text-center">
        <div class="w-11 h-11 bg-brand/10 rounded-xl flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-brand" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <p class="text-[10px] font-bold uppercase tracking-wider text-ink-400 mb-2">Sede</p>
        <p class="text-ink-900 font-bold text-sm">{site.address.city} ({site.address.province})</p>
        <p class="text-ink-400 text-xs mt-0.5">{site.address.street}</p>
      </div>

    </div>

    <div class="text-center">
      <p class="text-ink-500 mb-5 text-sm font-light">Vuoi un preventivo gratuito e senza impegno?</p>
      <a
        href={`tel:${site.phone}`}
        class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-brand-dark text-white px-8 sm:px-12 py-4 rounded-lg font-bold text-base sm:text-lg transition-all duration-200 shadow-[0_4px_16px_rgba(191,40,43,0.30)] hover:shadow-[0_6px_22px_rgba(191,40,43,0.40)] hover:-translate-y-px w-full sm:w-auto"
      >
        Chiamaci ora — è gratis
      </a>
    </div>

  </div>
</section>
