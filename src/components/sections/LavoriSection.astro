---
import { site } from '../../config/site';

interface Props {}
---

<section id="lavori" class="bg-warm-50 relative overflow-hidden py-14 sm:py-20 md:py-24">
  <!-- Sfumatura decorativa laterale -->
  <div
    class="from-warm-100/60 pointer-events-none absolute inset-y-0 right-0 w-1/3 bg-gradient-to-l to-transparent"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <p class="text-brand mb-3 text-xs font-bold tracking-[0.3em] uppercase sm:text-sm">Portfolio</p>
    <h2
      class="font-display text-ink-900 mb-5 text-2xl leading-snug font-bold sm:mb-6 sm:text-3xl md:text-4xl"
    >
      I nostri lavori
    </h2>

    <div class="bg-warm-300 mx-auto mb-6 h-px w-12"></div>

    <p class="text-ink-600 mx-auto mb-3 max-w-2xl text-base leading-relaxed sm:text-lg">
      Cucine complete, cabine armadio, librerie a parete: ogni lavoro parla da solo.
    </p>
    <p class="text-ink-400 mx-auto mb-10 max-w-xl text-base leading-relaxed sm:mb-12">
      Guarda le nostre foto su Facebook: vedrai la cura che mettiamo in ogni vite, ogni anta, ogni
      centimetro.
    </p>

    <a
      href={site.social.facebook}
      target="_blank"
      rel="noopener noreferrer"
      class="bg-brand hover:bg-brand-dark inline-flex w-full items-center justify-center gap-3 rounded-lg px-8 py-4 font-bold text-white shadow-[0_4px_16px_rgba(191,40,43,0.28)] transition-all duration-200 hover:-translate-y-px hover:shadow-[0_6px_22px_rgba(191,40,43,0.38)] sm:w-auto"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
      </svg>
      Guarda i nostri lavori su Facebook
    </a>
  </div>
</section>
