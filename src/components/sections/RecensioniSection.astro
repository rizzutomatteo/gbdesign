---
import { getCollection } from 'astro:content';
import { site } from '../../config/site';

const tutte = await getCollection('recensioni');
const reviews = tutte.sort((a, b) => b.data.data.getTime() - a.data.data.getTime());
---

<section id="recensioni" class="bg-white py-14 sm:py-20 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center sm:mb-16">
      <p class="text-brand mb-3 text-xs font-bold tracking-[0.3em] uppercase sm:text-sm">
        Cosa dicono di noi
      </p>
      <h2
        class="font-display text-ink-900 mb-5 text-2xl leading-snug font-bold sm:text-3xl md:text-4xl"
      >
        Le recensioni dei clienti
      </h2>
      <div class="flex flex-wrap items-center justify-center gap-1">
        {
          Array.from({ length: 5 }).map(() => (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="#bf282b"
              stroke="none"
              aria-hidden="true"
            >
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
            </svg>
          ))
        }
        <span class="text-ink-900 ml-2 text-lg font-bold">{site.stats.rating}</span>
        <span class="text-ink-400 ml-1 text-sm"
          >su Google ({site.stats.recensioni}+ recensioni)</span
        >
      </div>
    </div>

    <div class="mb-10 grid gap-5 sm:mb-12 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3">
      {
        reviews.map((r) => (
          <div class="bg-warm-50 border-warm-200 relative flex flex-col overflow-hidden rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.06)] transition-all duration-300 hover:shadow-[0_8px_28px_rgba(26,22,18,0.10)] sm:p-8">
            <div
              class="font-display text-brand/[0.08] pointer-events-none absolute -top-2 left-4 text-[5.5rem] leading-none select-none"
              aria-hidden="true"
            >
              "
            </div>
            <div class="relative z-10 mb-4 flex gap-0.5">
              {Array.from({ length: r.data.rating }).map(() => (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="#bf282b"
                  stroke="none"
                  aria-hidden="true"
                >
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                </svg>
              ))}
            </div>
            <p class="text-ink-700 relative z-10 mb-6 flex-1 text-base leading-relaxed italic">
              "{r.body.trim()}"
            </p>
            <div class="border-warm-200 relative z-10 border-t pt-4">
              <p class="text-ink-900 text-base font-semibold">{r.data.autore}</p>
              <p class="text-ink-400 mt-0.5 text-sm">{r.data.citta}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="text-center">
      <a
        href={site.googleReviews}
        target="_blank"
        rel="noopener noreferrer"
        class="border-warm-300 hover:border-brand text-ink-700 hover:text-brand hover:bg-warm-50 inline-flex w-full items-center justify-center gap-2 rounded-lg border-2 px-8 py-4 font-bold transition-all duration-200 sm:w-auto"
      >
        Leggi tutte le recensioni su Google →
      </a>
    </div>
  </div>
</section>
