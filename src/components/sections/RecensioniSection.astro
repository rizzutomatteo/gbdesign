---
import { site } from '../../config/site';

const reviews = [
  {
    name: 'Marco B.',
    city: 'Macerata',
    text: 'Professionali, puntuali e molto gentili. Hanno smontato e rimontato tutti i mobili senza un graffio. Lo consiglio a chiunque debba traslocare.',
    stars: 5,
  },
  {
    name: 'Laura V.',
    city: 'Civitanova Marche',
    text: 'Servizio eccellente dalla prima telefonata al montaggio finale. Il preventivo era preciso al centesimo, nessuna brutta sorpresa.',
    stars: 5,
  },
  {
    name: 'Azienda Rossi Srl',
    city: 'Porto Recanati',
    text: 'Hanno spostato il nostro ufficio in un solo weekend. Lunedì mattina eravamo già operativi. Massima efficienza e professionalità.',
    stars: 5,
  },
];
---

<section id="recensioni" class="py-14 sm:py-20 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12 sm:mb-16">
      <p class="text-brand text-[10px] sm:text-xs font-bold uppercase tracking-[0.3em] mb-3">Cosa dicono di noi</p>
      <h2 class="font-display font-bold text-ink-900 text-2xl sm:text-3xl md:text-4xl mb-5 leading-snug">Le recensioni dei clienti</h2>
      <div class="flex items-center justify-center gap-1 flex-wrap">
        {Array.from({ length: 5 }).map(() => (
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#bf282b" stroke="none" aria-hidden="true">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
          </svg>
        ))}
        <span class="text-ink-900 font-bold text-lg ml-2">{site.stats.rating}</span>
        <span class="text-ink-400 text-sm ml-1">su Google ({site.stats.recensioni}+ recensioni)</span>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6 mb-10 sm:mb-12">
      {reviews.map((review) => (
        <div class="relative bg-warm-50 rounded-2xl p-7 sm:p-8 border border-warm-200 shadow-[0_2px_12px_rgba(26,22,18,0.06)] hover:shadow-[0_8px_28px_rgba(26,22,18,0.10)] transition-all duration-300 flex flex-col overflow-hidden">
          <div class="font-display text-[5.5rem] leading-none text-brand/[0.08] absolute -top-2 left-4 select-none pointer-events-none" aria-hidden="true">"</div>
          <div class="flex gap-0.5 mb-4 relative z-10">
            {Array.from({ length: review.stars }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#bf282b" stroke="none" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
              </svg>
            ))}
          </div>
          <p class="text-ink-700 leading-relaxed text-sm mb-6 italic flex-1 relative z-10">"{review.text}"</p>
          <div class="border-t border-warm-200 pt-4 relative z-10">
            <p class="text-ink-900 font-semibold text-sm">{review.name}</p>
            <p class="text-ink-400 text-xs mt-0.5">{review.city}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center">
      <a
        href={site.googleReviews}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 border-2 border-warm-300 hover:border-brand text-ink-700 hover:text-brand px-8 py-4 rounded-lg font-bold transition-all duration-200 w-full sm:w-auto hover:bg-warm-50"
      >
        Leggi tutte le recensioni su Google →
      </a>
    </div>

  </div>
</section>
