---
interface Props {}
---

<section id="servizi" class="bg-warm-100 py-14 sm:py-20 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center sm:mb-16">
      <p class="text-brand mb-3 text-xs font-bold tracking-[0.3em] uppercase sm:text-sm">
        Cosa facciamo
      </p>
      <h2
        class="font-display text-ink-900 mb-4 text-2xl leading-snug font-bold sm:text-3xl md:text-4xl"
      >
        I nostri servizi
      </h2>
      <p class="text-ink-600 mx-auto max-w-xl text-base leading-relaxed sm:text-lg">
        Tre specializzazioni, un unico standard: lavoro preciso, tempi certi, nessuna sorpresa.
      </p>
    </div>

    <div class="mb-10 grid gap-5 sm:grid-cols-3 sm:gap-6">
      <!-- Traslochi residenziali -->
      <div
        class="bg-warm-50 border-warm-200 flex flex-col overflow-hidden rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] sm:p-8"
      >
        <div class="bg-brand/10 mb-5 flex h-11 w-11 items-center justify-center rounded-xl">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-brand"
            aria-hidden="true"
          >
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
        </div>
        <h3 class="font-display text-ink-900 mb-3 text-xl leading-snug font-bold">
          Traslochi residenziali
        </h3>
        <p class="text-ink-600 flex-1 text-base leading-relaxed">
          Imballiamo tutto, carichiamo, trasportiamo e rimettiamo a posto nella nuova casa.
          Smontaggio e rimontaggio mobili inclusi. Tu arrivi e trovi tutto pronto.
        </p>
      </div>

      <!-- Traslochi aziendali -->
      <div
        class="bg-warm-50 border-warm-200 flex flex-col overflow-hidden rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] sm:p-8"
      >
        <div class="bg-brand/10 mb-5 flex h-11 w-11 items-center justify-center rounded-xl">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-brand"
            aria-hidden="true"
          >
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
        </div>
        <h3 class="font-display text-ink-900 mb-3 text-xl leading-snug font-bold">
          Traslochi aziendali
        </h3>
        <p class="text-ink-600 flex-1 text-base leading-relaxed">
          Spostiamo uffici, attività commerciali e magazzini senza fermare la tua produttività.
          Lavoriamo nel weekend: lunedì mattina sei già operativo nella nuova sede.
        </p>
      </div>

      <!-- Montaggio mobili -->
      <div
        class="bg-warm-50 border-warm-200 flex flex-col overflow-hidden rounded-2xl border p-7 shadow-[0_2px_12px_rgba(26,22,18,0.07)] sm:p-8"
      >
        <div class="bg-brand/10 mb-5 flex h-11 w-11 items-center justify-center rounded-xl">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-brand"
            aria-hidden="true"
          >
            <path
              d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"
            ></path>
          </svg>
        </div>
        <h3 class="font-display text-ink-900 mb-3 text-xl leading-snug font-bold">
          Montaggio e smontaggio mobili
        </h3>
        <p class="text-ink-600 flex-1 text-base leading-relaxed">
          Cucine complete, cabine armadio, librerie a parete, arredi su misura. Montaggi di pregio
          con la cura del dettaglio che differenzia un lavoro fatto bene da uno fatto in fretta.
        </p>
      </div>
    </div>

    <div class="text-center">
      <a
        href="/divisioni"
        class="border-warm-300 hover:border-brand text-ink-700 hover:text-brand inline-flex items-center justify-center gap-2 rounded-lg border-2 px-8 py-4 font-bold transition-all duration-200 hover:bg-white"
      >
        Scopri tutte le divisioni →
      </a>
    </div>
  </div>
</section>
