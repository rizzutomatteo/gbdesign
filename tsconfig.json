{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "node_modules", ".netlify", "test-results", "playwright-report"],
  "compilerOptions": {
    "resolveJsonModule": true,
    "paths": {
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@config": ["./src/config/site.ts"]
    }
  }
}
